---
import config from "$config";
import Base from "$layouts/Base.astro";
import i18nit from "$i18n";

export async function getStaticPaths() {
	return config.i18n.locales.map(locale => ({ params: { locale: config.i18n.defaultLocale === locale ? undefined : locale } }));
}

const { locale = config.i18n.defaultLocale } = Astro.params;
const t = i18nit(locale);
---

<Base {locale} title={t("navigation.email")}>
	<main class="grow-[0.25] flex items-center justify-center font-bold text-2xl" id="email-verify-status">{t("loading")}</main>
</Base>

<script is:inline>
	(async () => {
		const el = document.getElementById("email-verify-status");
		if (!el) return;

		const ticket = new URL(location.href).searchParams.get("ticket");
		if (!ticket) {
			el.textContent = "Invalid request";
			return;
		}

		try {
			const response = await fetch(`/@/email/verify?ticket=${encodeURIComponent(ticket)}`, { credentials: "include" });
			const payload = await response.json().catch(() => undefined);
			if (!response.ok) throw new Error(payload?.error ?? response.statusText);

			el.textContent = payload?.message ?? payload?.result ?? "Email verified";
		} catch {
			el.textContent = "Verification failed";
		}
	})();
</script>

