---
import config from "$config";
import App from "$layouts/App.astro";
import Header from "$layouts/header/Header.astro";
import Footer from "$layouts/Footer.astro";
import Tip from "$components/Tip.svelte";
import "$styles/global.css";
import "$styles/markdown.css";
import "medium-zoom/dist/style.css";

const { locale = config.i18n.defaultLocale, title: subtitle, description = config.description, article, math = false } = Astro.props;
const title = config.title;
---

<script>
	import Time from "$utils/time-client";

	// Set the `title` attribute of all `<time>` elements to localized date-time strings
	const localizeTimes = () => document.querySelectorAll("time").forEach(time => time.dateTime && (time.title = Time.toLocaleString(time.dateTime, navigator.language, true)));

	type ZoomInstance = {
		detach: () => unknown;
		attach: (...selectors: unknown[]) => unknown;
	};

	let zoom: ZoomInstance | undefined;
	let zoomReady: Promise<ZoomInstance> | undefined;

	async function ensureZoom() {
		if (!document.querySelector(".markdown img:not([data-nozoom])")) return;

		if (!zoomReady) {
			zoomReady = import("medium-zoom/dist/pure").then(({ default: mediumZoom }) => {
				zoom = mediumZoom(undefined, { background: "#00000044" }) as ZoomInstance;
				return zoom;
			});
		}

		const instance = await zoomReady;
		if (!instance) return;
		instance.detach();
		instance.attach(".markdown img:not([data-nozoom])");
	}

	window.zoom = () => void ensureZoom();

	const shouldInstallRenderDebug = () => {
		const query = new URLSearchParams(location.search).get("__render_debug");
		if (query === "1") return true;
		if (query === "0") return false;
		try {
			return localStorage.getItem("__render_debug_enabled_v1") === "1";
		} catch {
			return false;
		}
	};

	// Page initialization function
	async function initialize() {
		localizeTimes();
		await ensureZoom();
	}

	// Execute initialization on first load
	void initialize();

	if (shouldInstallRenderDebug()) {
		void import("$utils/render-debug").then(({ installRenderDebug }) => installRenderDebug());
	}

	// Listen for page load event and re-initialize on page transitions
	document.addEventListener("astro:page-load", () => void initialize());
</script>

<App {locale} {title} {subtitle} {description} {article} {math} author={config.author.name}>
	<Tip client:load />
	<div class="flex flex-col mx-auto *:*:px-3 w-[min(100%,1000px)]">
		<!-- Stretch body to full viewport height to prevent layout jumps from toggleable scrollbars. -->
		<div id="body" class="flex flex-col min-h-screen">
			<Header {locale} {title} />

			<slot />
		</div>

		<Footer {locale} author={config.author} copyright={config.copyright} />
	</div>
</App>
