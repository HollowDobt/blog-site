---
import { getRelativeLocaleUrl } from "astro:i18n";
import { turnstile } from "$config";

const { locale, title, subtitle, description, author, article } = Astro.props;
---

<html lang={locale} dir={["ar", "he", "fa", "ur"].includes(locale) ? "rtl" : "ltr"}>
	<head>
		<title>{subtitle && `${subtitle} |`} {title}</title>
		<meta name="description" content={description} />

		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="alternate" type="application/atom+xml" {title} href={getRelativeLocaleUrl(locale, "/feed.xml")} />

		<meta property="og:title" content={`${subtitle && `${subtitle} | `}${title}`} />
		<meta property="og:type" content={(article && "article") || "website"} />
		<meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content={title} />
		<meta property="og:locale" content={locale.replace(/-(\w+)/, (_: any, region: string) => `_${region.toUpperCase()}`)} />

		<meta property="og:image" content={new URL("linkback.webp", Astro.site)} />
		<meta property="og:image:alt" content={title} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />

		{article && [<meta property="article:author" content={author} />, <meta property="article:published_time" content={article.timestamp.toISOString()} />, article.section && <meta property="article:section" content={article.section} />, article.tags?.map((tag: string) => <meta property="article:tag" content={tag} />)]}

		<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="sitemap" href="/sitemap-index.xml" />

		{turnstile && [<script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit&onload=onloadTurnstileCallback" async defer data-swup-ignore-script is:inline />]}

		<script is:inline>
			var theme = localStorage.getItem("theme");
			var prefers = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
			document.documentElement.dataset.theme = theme || prefers;
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>
